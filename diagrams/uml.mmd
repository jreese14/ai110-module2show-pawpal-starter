classDiagram
    class Owner {
        -name: String
        -available_time: int
        -pets: List~Pet~
        +update_info()
        +set_available_time(time: int)
    }

    class Pet {
        -name: String
        -species: String
        -age: int
        -owner: Owner
        +update_info()
        +display_info()
    }

    class Task {
        -task_name: String
        -duration: int
        -priority: int
        -completed: boolean
        -owner: Owner
        -pet: Pet
        +mark_complete()
        +edit_task()
    }

    class Schedule {
        -owner: Owner
        -tasks: List~Task~
        +add_task(task: Task)
        +generate_schedule()
        +display_schedule()
    }

    Owner "1" --> "1..*" Pet : owns
    Owner "1" --> "1" Schedule : creates
    Task "1..*" --> "1" Pet : assigned_to
    Task "1..*" --> "1" Owner : for
    Schedule "1" --> "1..*" Task : contains
